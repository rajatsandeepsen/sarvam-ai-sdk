{
  "name": "ai-sdk-docs",
  "version": "0.0.0",
  "private": true,
  "description": "Documentation site for the AI SDK (ai-sdk.dev), built with @vercel/geistdocs.",
  "scripts": {
    "sync-content": "node scripts/sync-content.mjs",
    "dev:site": "pnpm sync-content && fumadocs-mdx && next dev",
    "build:site": "pnpm sync-content && fumadocs-mdx && next build",
    "start:site": "next start",
    "type-check:site": "pnpm sync-content && fumadocs-mdx && tsc --noEmit",
    "test:site": "node --test scripts/*.test.mjs",
    "validate:site": "pnpm test:site && pnpm build:site"
  },
  "dependencies": {
    "@shikijs/transformers": "3.23.0",
    "@vercel/geistdocs": "1.11.3",
    "fumadocs-core": "16.2.2",
    "fumadocs-mdx": "14.0.4",
    "fumadocs-ui": "16.2.2",
    "next": "16.2.6",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "shiki": "3.23.0",
    "streamdown": "^2.1.0",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.17",
    "@types/mdx": "^2.0.13",
    "@types/node": "22.19.19",
    "@types/react": "18.3.28",
    "@types/react-dom": "18.3.7",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.17",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3"
  }
}
