{
	"name": "sarvam-ai-sdk",
	"type": "module",
	"description": "Sarvam provider support for Vercel's AI-SDK",
	"version": "0.4.1",
	"main": "./dist/index.cjs",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"files": [
		"dist/**/*"
	],
	"scripts": {
		"build": "tsdown",
		"build:watch": "tsdown --watch",
		"type-check": "tsc --noEmit",
		"check": "biome check",
		"test": "tsx --env-file=.env test/index.ts"
	},
	"exports": {
		"./package.json": "./package.json",
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"require": "./dist/index.cjs"
		}
	},
	"dependencies": {
		"@ai-sdk/provider": "^3.0.0",
		"@ai-sdk/provider-utils": "^4.0.0"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.8",
		"@types/node": "20.17.24",
		"ai": "^6.0.0",
		"tsdown": "^0.15.10",
		"tsx": "^4.21.0",
		"typescript": "5.6.3",
		"zod": "^4.1.8"
	},
	"peerDependencies": {
		"ai": "^6.0.0",
		"zod": "^3.25.0 || ^4.0.0"
	},
	"engines": {
		"node": ">=18"
	},
	"publishConfig": {
		"access": "public"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/sarvamai/sarvam-ai-sdk.git"
	},
	"bugs": {
		"url": "https://github.com/sarvamai/sarvam-ai-sdk/issues"
	},
	"homepage": "https://docs.sarvam.ai",
	"keywords": [
		"ai",
		"ai-sdk",
		"sarvam",
		"india",
		"ai4bharat"
	]
}
